# NextAuth secret — generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-random-secret"

# --- min-idp (default) ---
AUTH_MIN_IDP_ISSUER="http://localhost:8081"
AUTH_MIN_IDP_ID="my-app-client"
AUTH_MIN_IDP_SECRET="super-secret"

# --- Authentik example ---
# AUTH_MIN_IDP_ISSUER="http://<authentik-host>/application/o/<app-slug>/"
# AUTH_MIN_IDP_ID="<client-id>"
# AUTH_MIN_IDP_SECRET="<client-secret>"

# HTTP server host and port — managed by go-minstack/gin.
MINSTACK_HOST=
MINSTACK_PORT=8080
# Also accepted: MINSTACK_HTTP_PORT (takes precedence over MINSTACK_PORT)
# MINSTACK_HTTP_PORT=8080

# CORS allowed origins. Comma-separated list or * for wildcard.
# Required for browser-based OIDC public clients calling the token endpoint.
# MINSTACK_CORS_ORIGIN=http://localhost:5173,http://localhost:3000,https://app.example.com

# Log level: debug | info | warn | error  (default: info)
MINSTACK_LOG_LEVEL=info

# Log format: json | text  (default: json)
MINSTACK_LOG_FORMAT=json

# Public base URL of this IdP — used in OIDC discovery, SAML metadata, and token issuers.
MIN_IDP_EXTERNAL_URL=http://localhost:8080

# Database driver: sqlite | mysql | postgres
MIN_IDP_DB_DRIVER=sqlite

# Database connection string. For SQLite, a file path. For MySQL/Postgres, a DSN.
MIN_IDP_DB_DSN=./dev.db

# 32-byte AES master key (base64-encoded) used to encrypt signing keys at rest.
# Generate with: openssl rand -base64 32
MIN_IDP_MASTER_KEY=

# KV store driver: db (default, uses kv_store table) | redis
MIN_IDP_KV_DRIVER=db

# Redis URL — only required when MIN_IDP_KV_DRIVER=redis.
# MIN_IDP_KV_REDIS_URL=redis://localhost:6379

# Name of the IdP session cookie.
MIN_IDP_SESSION_COOKIE=min_idp_session

# Absolute lifetime of a session from creation.
MIN_IDP_SESSION_TTL=12h

# Idle timeout — sessions inactive longer than this are considered expired.
MIN_IDP_SESSION_IDLE=1h

# Lifetime of password reset tokens emailed to users.
MIN_IDP_PASSWORD_RESET_TTL=15m

# First-run bootstrap app (OIDC). Created once on a fresh database.
MIN_IDP_BOOTSTRAP_SP_NAME=Default App
MIN_IDP_BOOTSTRAP_SP_REDIRECT_URIS=http://localhost:3000/callback
MIN_IDP_BOOTSTRAP_SP_CLIENT_ID=default
# Pin the client secret so DB resets re-bootstrap the same credentials.
# Leave empty to generate a random secret (recommended for production).
MIN_IDP_BOOTSTRAP_SP_CLIENT_SECRET=dev-client-secret-change-me
# Set true for SPAs: public client with PKCE, no secret (secret above is ignored).
MIN_IDP_BOOTSTRAP_SP_PUBLIC=false

# Allow self-registration via POST /api/auth/register.
MIN_IDP_FEATURE_API_REGISTRATION=false

# Allow direct API login via POST /api/auth/login (disable to force SSO-only).
MIN_IDP_FEATURE_API_LOGIN=true

# Enable outbound email via SMTP (required for password recovery and magic link).
MIN_IDP_SMTP_ENABLED=false

# SMTP server settings — required when MIN_IDP_SMTP_ENABLED=true.
# MIN_IDP_SMTP_HOST=smtp.example.com
# MIN_IDP_SMTP_PORT=587
# MIN_IDP_SMTP_USERNAME=
# MIN_IDP_SMTP_PASSWORD=
# MIN_IDP_SMTP_FROM=noreply@example.com
# MIN_IDP_SMTP_FROM_NAME=min-idp
# MIN_IDP_SMTP_TLS=starttls

SAML_SP_ENTITY_ID=http://localhost:3002
SAML_SP_ACS_URL=http://localhost:3002/api/auth/saml/callback

SAML_SP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
SAML_SP_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# IdP — fill in from IdP metadata
SAML_IDP_ENTITY_ID=
SAML_IDP_SSO_URL=
SAML_IDP_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# Set to "false" to skip signing AuthnRequests (no need to register SP cert in IdP)
# When "true" (default): SP signs requests; IdP only enforces verification if a cert is registered
# When "false": SP sends unsigned requests; IdP must NOT have a verification cert configured
SAML_SP_SIGN_REQUESTS=true

# Generate with: openssl rand -hex 32
SESSION_SECRET=
